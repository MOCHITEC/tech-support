# これを terraform.tfvars にコピーして値を埋める(terraform.tfvars は git 管理しない)。

project_id = "your-gcp-project-id"
region     = "asia-northeast1"

github_repository     = "MOCHITEC/tech-support"
github_default_branch = "main"

# エージェントが自動生成する PR の作成先ブランチ(既定 demo)。
pr_base_branch = "demo"

# Cloud SQL(ハッカソンは最小構成)
db_tier = "db-f1-micro"

# GitHub ブランチ保護は別モジュール infra/github-branch-protection/ で適用する(任意)。
